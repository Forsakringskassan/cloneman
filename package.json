{
  "name": "cloneman",
  "version": "1.7.0",
  "description": "Application template and lifecycle management tool",
  "keywords": [
    "template",
    "lifecycle"
  ],
  "homepage": "https://github.com/Forsakringskassan/cloneman#readme",
  "bugs": {
    "url": "https://github.com/Forsakringskassan/cloneman/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/cloneman.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "bin": {
    "cloneman": "./bin/cloneman.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "attw": "npx @arethetypeswrong/cli --profile esm-only --no-emoji --pack .",
    "prebuild": "tsc",
    "build": "node ./build.mjs",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --fix .",
    "lint": "run-s eslint prettier:check",
    "lint:fix": "run-s eslint:fix prettier:write",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "postpublish": "release-postpublish",
    "pretest": "npm run lint",
    "test": "vitest run",
    "version": "scripts/version"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "dependencies": {
    "deepmerge": "4.3.1",
    "nano-spawn": "2.1.0",
    "sort-package-json": "3.6.1",
    "tar": "7.5.13",
    "yargs": "18.0.0",
    "yocto-spinner": "1.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@forsakringskassan/commitlint-config": "3.3.11",
    "@forsakringskassan/eslint-config": "14.1.11",
    "@forsakringskassan/eslint-config-cli": "14.1.11",
    "@forsakringskassan/eslint-config-typescript": "14.1.10",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "14.1.10",
    "@forsakringskassan/eslint-config-vitest": "14.1.9",
    "@forsakringskassan/prettier-config": "3.3.9",
    "@html-validate/release-scripts": "7.1.19",
    "@microsoft/api-extractor": "7.58.2",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/deepmerge": "2.1.0",
    "@types/stream-buffers": "3.0.8",
    "@types/yargs": "17.0.35",
    "@verdaccio/types": "10.8.0",
    "esbuild": "0.28.0",
    "is-ci": "4.1.0",
    "npm-pkg-lint": "4.6.5",
    "npm-run-all2": "8.0.4",
    "pretty-ansi": "4.0.0",
    "stream-buffers": "3.0.3",
    "typescript": "6.0.2",
    "verdaccio": "6.5.0",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">= 22.20.0 || >= 24.8.0",
    "npm": ">= 11.0.0"
  }
}
