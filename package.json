{
  "name": "cloneman",
  "version": "1.0.0",
  "description": "Application template and lifecycle management tool",
  "keywords": [
    "template",
    "lifecycle"
  ],
  "homepage": "https://github.com/Forsakringskassan/cloneman#readme",
  "bugs": {
    "url": "https://github.com/Forsakringskassan/cloneman/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/cloneman.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "cloneman": "./bin/cloneman.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "attw": "npx @arethetypeswrong/cli --profile esm-only --no-emoji --pack .",
    "prebuild": "tsc",
    "build": "node ./build.mjs",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --fix .",
    "lint": "run-s eslint prettier:check",
    "lint:fix": "run-s eslint:fix prettier:write",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle",
    "postpublish": "release-postpublish",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "pretest": "npm run lint",
    "version": "scripts/version",
    "test": "vitest run"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@forsakringskassan/commitlint-config": "3.3.7",
    "@forsakringskassan/eslint-config": "13.5.2",
    "@forsakringskassan/eslint-config-cli": "13.5.0",
    "@forsakringskassan/eslint-config-typescript": "13.5.0",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "13.5.0",
    "@forsakringskassan/eslint-config-vitest": "13.5.3",
    "@forsakringskassan/prettier-config": "3.3.5",
    "@html-validate/release-scripts": "7.1.15",
    "@microsoft/api-extractor": "7.57.6",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/stream-buffers": "3.0.8",
    "@types/yargs": "17.0.35",
    "@verdaccio/types": "10.8.0",
    "esbuild": "0.27.3",
    "is-ci": "4.1.0",
    "npm-pkg-lint": "4.4.1",
    "npm-run-all2": "8.0.4",
    "stream-buffers": "3.0.3",
    "typescript": "5.9.3",
    "verdaccio": "6.3.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">= 22.20.0 || >= 24.8.0",
    "npm": ">= 11.0.0"
  },
  "dependencies": {
    "nano-spawn": "2.0.0",
    "sort-package-json": "3.6.1",
    "tar": "7.5.10",
    "yargs": "18.0.0"
  }
}
