{
    "extends": [
        "@tsconfig/recommended",
        "@tsconfig/strictest",
        "@tsconfig/node22"
    ],
    "compilerOptions": {
        "rootDirs": ["fixtures", "src"],
        "outDir": "dist",
        "declarationDir": "temp/types",

        "module": "esnext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "resolveJsonModule": true,

        /* needed by esm-resolve */
        "customConditions": ["node"],

        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["esnext"],
        "noUncheckedIndexedAccess": false,
        "skipLibCheck": true,

        "paths": {
            "cloneman": ["./src/index.ts"]
        }
    },
    "include": ["fixtures/**/.cloneman/*.mts", "src/**/*.ts"],
    "exclude": ["node_modules"]
}
