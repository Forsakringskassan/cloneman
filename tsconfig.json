{
    "extends": [
        "@tsconfig/recommended",
        "@tsconfig/strictest",
        "@tsconfig/node22"
    ],
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "declarationDir": "temp/types",

        "module": "esnext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "resolveJsonModule": true,

        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["esnext"],
        "noUncheckedIndexedAccess": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"]
}
